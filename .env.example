# Google Service Account kimlik bilgileri
SA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
SA_PRIVATE_KEY_ID=your_private_key_id
SA_CLIENT_ID=your_client_id
SA_PROJECT_ID=your-gcp-project-id

# RSA özel anahtarı — gerçek \n karakterleri kullanın (kaçış dizisi değil)
SA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Google Drive kaynak klasörü
SOURCE_FOLDER_ID=your_google_drive_folder_id
